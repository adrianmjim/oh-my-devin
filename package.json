{
  "name": "oh-my-devin",
  "version": "0.0.0",
  "description": "An organizational layer on top of the Devin CLI: functional roles, declarative teams, and deliberative councils over local Devin sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianmjim/oh-my-devin.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "omd": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "tsc-alias": "1.9.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "3.2.7"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "yaml": "2.9.0"
  }
}
